{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/portfolio",
            "destination": "/portfolio.html"
        },
        {
            "source": "/portfolio/:path*",
            "destination": "/portfolio.html"
        },
        {
            "source": "/((?!.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}